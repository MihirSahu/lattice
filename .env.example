LATTICE_APP_NAME=Lattice
LATTICE_PUBLIC_URL=https://lattice.example.com
LATTICE_DATA_ROOT=../../data/runtime

WEB_PORT=3000
WEB_INTERNAL_PORT=3000
WEB_SYNC_WORKER_URL=http://sync-worker:4000
WEB_QMD_SERVICE_URL=http://qmd:8181
WEB_OPENCODE_SERVICE_URL=http://opencode-query:8282
WEB_DEFAULT_QUERY_LIMIT=6

QMD_PORT=8181
QMD_DB_PATH=/var/lib/qmd/index.sqlite
QMD_COLLECTION=vault
QMD_RESULT_LIMIT=6
OPENCODE_QUERY_PORT=8282
OPENCODE_QUERY_TIMEOUT_MS=120000
OPENCODE_MODEL=openrouter/anthropic/claude-sonnet-4.6

SYNC_WORKER_PORT=4000
SYNC_INTERVAL_SECONDS=300
SYNC_AWS_REGION=us-east-1
SYNC_S3_BUCKET=your-bucket
SYNC_S3_PREFIX=obsidian-vault/
SYNC_DELETE=false
VAULT_MIRROR_DIR=/srv/vault-mirror
STATUS_DIR=/var/lib/lattice
LOG_DIR=/var/log/lattice
QMD_EMBED_STRATEGY=on-change

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
OPENROUTER_API_KEY=

CLOUDFLARE_TUNNEL_TOKEN=
