{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListVaultPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "YOUR_PREFIX/*",
            "YOUR_PREFIX"
          ]
        }
      }
    },
    {
      "Sid": "ReadVaultObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/YOUR_PREFIX/*"
    }
  ]
}

